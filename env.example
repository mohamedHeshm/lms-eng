# ==================== بيانات Supabase ====================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-key

# ==================== اختر نوع خدمة الواتساب ====================
# اختر واحدة: 'cloudapi' أو 'twilio'
WHATSAPP_TYPE=cloudapi

# ==================== إذا كنت تستخدم WhatsApp Cloud API ====================
# احصل عليها من: https://developers.facebook.com/docs/whatsapp/cloud-api/

WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-access-token
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id

# ==================== أو إذا كنت تستخدم Twilio ====================
# احصل عليها من: https://www.twilio.com/console/sms/whatsapp/sandbox

TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_WHATSAPP_NUMBER=+1234567890

# ==================== إعدادات الخادم ====================
NODE_ENV=production
PORT=3000

# ==================== معالجة الرسائل ====================
# عدد الرسائل المعالجة في كل دورة (1-100)
BATCH_SIZE=50

# فترة معالجة الرسائل بالدقائق (افتراضي: 5 دقائق)
PROCESS_INTERVAL_MINUTES=5

# ==================== السجلات ====================
LOG_LEVEL=info
